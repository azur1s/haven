// Static strings: `str` is an &'static str, i.e. a { ptr, i32 } fat pointer
// into a read-only global blob. This test is self-contained: main returns an
// exit code that is only 0 when every check holds.

// str as a parameter (passed by fat pointer)
proc length_of(s: str) i32 {
    return len(s);
}

// str as a return value
proc greeting() str {
    return "hello";
}

@export
proc main() i32 {
    // basic literal
    let hi: str = "\thello"; // 5 bytes
    let empty: str = "";     // 0 bytes

    println(hi);

    // escape sequences are resolved to real bytes, not kept literally:
    //   \n \t \r \0 each count as one byte, \\ and \" too
    let escapes: str = "a\nb\tc"; // a \n b \t c = 5 bytes
    let quoted: str = "\"\\";     // " \ = 2 bytes

    // identical literals are deduplicated into one global, but still equal len
    let hi_again: str = "\thello";

    // check lengths
    if (len(hi) != 6) { println("len(hi) != 6"); }
    if (len(empty) != 0) { println("len(empty) != 0"); }
    if (len(escapes) != 5) { println("len(escapes) != 5"); }
    if (len(quoted) != 2) { println("len(quoted) != 2"); }
    if (len(hi_again) != 6) { println("len(hi_again) != 6"); }

    return 0;
}
