import std/dsp/osc
import std/dsp/filters

// Exercise the stateful DSP structs. We don't check exact numbers here; the
// point is that construction, pointer-mutating process calls, and struct
// returns all lower and run. Feed a few samples through each and print.

@export
proc main() i32 {
    let sr: f32 = 48000.0;

    // Osc: run one sine and one saw for a few samples
    let o: Osc = osc_new(1000.0, sr);
    let i: i32 = 0;
    print("osc_sine:\n");
    while (i < 4) {
        print_float(osc_sine(&o));
        i = i + 1;
    }

    let saw: Osc = osc_new(1000.0, sr);
    i = 0;
    print("osc_saw:\n");
    while (i < 4) {
        print_float(osc_saw(&saw));
        i = i + 1;
    }

    // Phasor
    let p: Phasor = phasor_new(1000.0, sr);
    print("phasor:\n");
    print_float(phasor_next(&p));
    print_float(phasor_next(&p));

    // OnePole lowpass driven by a step input
    let lp: OnePole = onepole_lowpass(2000.0, sr);
    print("onepole (step response):\n");
    i = 0;
    while (i < 4) {
        print_float(onepole_process(&lp, 1.0));
        i = i + 1;
    }

    // Biquad lowpass, step input
    let bq: Biquad = biquad_lowpass(2000.0, 0.707, sr);
    print("biquad lowpass (step response):\n");
    i = 0;
    while (i < 4) {
        print_float(biquad_process(&bq, 1.0));
        i = i + 1;
    }

    // StateVariable: all four outputs from one pass
    let svf: StateVariable = svf_new(2000.0, 0.707, sr);
    print("svf (step response, lp/hp/bp/notch):\n");
    i = 0;
    while (i < 3) {
        let out: SvfOut = svf_process(&svf, 1.0);
        print_float(out.lp);
        print_float(out.hp);
        print_float(out.bp);
        print_float(out.notch);
        i = i + 1;
    }

    return 0;
}
