@export
proc main() i32 {
    let a: i32 = 0; // default
    let b: i32 = 0i32;
    let c: i64 = 0i64;
    let d: u32 = 0u32;
    let e: u64 = 0u64;

    let f: f32 = 0.0; // default
    let g: f32 = 0.0f32;
    let h: f64 = 0.0f64;

    // from i32
    let u1: i32 = numerical_cast::<i32>(0i32);
    let u2: i64 = numerical_cast::<i64>(0i32);
    let u3: u32 = numerical_cast::<u32>(0i32);
    let u4: u64 = numerical_cast::<u64>(0i32);
    let u5: f32 = numerical_cast::<f32>(0i32);
    let u6: f64 = numerical_cast::<f64>(0i32);

    // from i64
    let v1: i32 = numerical_cast::<i32>(0i64);
    let v2: i64 = numerical_cast::<i64>(0i64);
    let v3: u32 = numerical_cast::<u32>(0i64);
    let v4: u64 = numerical_cast::<u64>(0i64);
    let v5: f32 = numerical_cast::<f32>(0i64);
    let v6: f64 = numerical_cast::<f64>(0i64);

    // from u32
    let w1: i32 = numerical_cast::<i32>(0u32);
    let w2: i64 = numerical_cast::<i64>(0u32);
    let w3: u32 = numerical_cast::<u32>(0u32);
    let w4: u64 = numerical_cast::<u64>(0u32);
    let w5: f32 = numerical_cast::<f32>(0u32);
    let w6: f64 = numerical_cast::<f64>(0u32);

    // from u64
    let x1: i32 = numerical_cast::<i32>(0u64);
    let x2: i64 = numerical_cast::<i64>(0u64);
    let x3: u32 = numerical_cast::<u32>(0u64);
    let x4: u64 = numerical_cast::<u64>(0u64);
    let x5: f32 = numerical_cast::<f32>(0u64);
    let x6: f64 = numerical_cast::<f64>(0u64);

    // from f32
    let y1: i32 = numerical_cast::<i32>(0.0f32);
    let y2: i64 = numerical_cast::<i64>(0.0f32);
    let y3: u32 = numerical_cast::<u32>(0.0f32);
    let y4: u64 = numerical_cast::<u64>(0.0f32);
    let y5: f32 = numerical_cast::<f32>(0.0f32);
    let y6: f64 = numerical_cast::<f64>(0.0f32);

    // from f64
    let z1: i32 = numerical_cast::<i32>(0.0f64);
    let z2: i64 = numerical_cast::<i64>(0.0f64);
    let z3: u32 = numerical_cast::<u32>(0.0f64);
    let z4: u64 = numerical_cast::<u64>(0.0f64);
    let z5: f32 = numerical_cast::<f32>(0.0f64);
    let z6: f64 = numerical_cast::<f64>(0.0f64);

    return 0;
}