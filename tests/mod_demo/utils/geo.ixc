// A local module: exports a struct and a function. Referenced by the entry via
// a whole-module `import utils/geo`, so `Point` and `manhattan` are unqualified.

struct Point { x: i32, y: i32 }

proc manhattan(p: Point) i32 {
    let ax: i32 = p.x;
    let ay: i32 = p.y;
    if (ax < 0) { ax = 0 - ax; }
    if (ay < 0) { ay = 0 - ay; }
    return ax + ay;
}
