// Stage-3 Phase 4: a data-carrying enum crosses @export as a committed
// `{ tag: repr, payload: union }` aggregate, ABI-lowered exactly like a
// by-value struct (register coercion / byval / sret, see haven_back::abi).
// `@repr` is required (like Rust's `#[repr(C)]`) before either enum may cross.

@repr(C)
enum Msg { Stop, Note(u8, f32) }

// a variant holding a pointer needs 8-byte alignment even though the tag's
// default `i32` repr only needs 4 - the payload must be placed (and the whole
// aggregate sized) accordingly, not packed right after the tag as raw bytes.
@repr(C)
enum Ptrish { A(*i32) }

@export
proc take(m: Msg) i32 {
    match (m) {
        Msg::Note(a, b) -> { return numerical_cast::<i32>(a) + numerical_cast::<i32>(b); }
        Msg::Stop -> { return -1; }
    }
}

@export
proc make(v: u8, f: f32) Msg {
    return Msg::Note(v, f);
}

@export
proc main() i32 {
    // sizeof::<Ptrish>(): tag (i32, 4/4) padded up to the pointer's 8-byte
    // alignment, then the 8-byte pointer payload - 16, not the 12 a naive
    // `[8 x i8]` byte-blob placement would give.
    printf::<u64>("%llu\n", sizeof::<Ptrish>()); // 16

    printf::<i32>("%d\n", take(Msg::Stop));          // -1
    printf::<i32>("%d\n", take(Msg::Note(5u8, 6.0f32))); // 11

    let m: Msg = make(7u8, 8.0f32);
    printf::<i32>("%d\n", take(m));                  // 15

    return 0;
}
