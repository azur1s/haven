// A data-carrying enum variant may hold a concrete generic instance as its
// payload (`Full(Vec<i32>)`): the module resolver rewrites payload field types
// just like struct fields, and monomorphization emits the instance. Covers both
// a non-generic enum and a generic enum whose payloads mix a type param (`T`)
// with a concrete instance (`Vec<i32>`).

import std/vec { Vec, vec_new, vec_push, vec_get, vec_len }

@repr(C)
enum Bag { Empty, Full(Vec<i32>) }

@repr(C)
enum Wrap<T> { Nil, One(T), Many(Vec<i32>) }

proc bag_first(b: Bag) i32 {
    match (b) {
        Bag::Empty -> { return -1; }
        Bag::Full(v) -> { return vec_get::<i32>(&v, 0u64); }
    }
}

@export
proc main() i32 {
    let xs: Vec<i32> = vec_new::<i32>();
    vec_push::<i32>(&xs, 42);
    vec_push::<i32>(&xs, 7);
    printf::<i32>("%d\n", bag_first(Bag::Full(xs))); // 42
    printf::<i32>("%d\n", bag_first(Bag::Empty));    // -1

    // generic enum: the concrete-instance payload
    let ys: Vec<i32> = vec_new::<i32>();
    vec_push::<i32>(&ys, 100);
    vec_push::<i32>(&ys, 200);
    let w: Wrap<i32> = Wrap::Many::<i32>(ys);
    match (w) {
        Wrap::Nil -> { printf::<i32>("%d\n", 0); }
        Wrap::One(x) -> { printf::<i32>("%d\n", x); }
        Wrap::Many(v) -> { printf::<i32>("%d\n", vec_get::<i32>(&v, 1u64)); } // 200
    }

    // generic enum: the type-param payload
    let single: Wrap<i32> = Wrap::One::<i32>(9);
    match (single) {
        Wrap::Nil -> { printf::<i32>("%d\n", 0); }
        Wrap::One(x) -> { printf::<i32>("%d\n", x); } // 9
        Wrap::Many(v) -> { printf::<i32>("%d\n", numerical_cast::<i32>(vec_len::<i32>(&v))); }
    }
    return 0;
}
