// std/string: build, borrow-as-`str`, compare, clear, and grow an owned String.

import std/string {
    String, string_new, string_with_capacity, string_from_str,
    string_push_byte, string_push_str, string_len, string_cap,
    string_is_empty, string_eq, string_as_str, string_clear, string_free,
}

// bool isn't numeric, so funnel truthiness through an i32 for `%d` printing.
proc yn(b: bool) i32 { if (b) { return 1; } return 0; }

@export
proc main() i32 {
    // build a string from a mix of str fragments and raw bytes
    let s: String = string_new();
    string_push_str(&s, "Hello");
    string_push_byte(&s, 44u8);  // ','
    string_push_byte(&s, 32u8);  // ' '
    string_push_str(&s, "world");
    string_push_byte(&s, 33u8);  // '!'
    printf::<str>("%s\n", string_as_str(&s)); // Hello, world!
    printf::<u64>("%llu\n", string_len(&s));  // 13

    // seed from a literal
    let greet: String = string_from_str("hi");
    printf::<str>("%s\n", string_as_str(&greet));       // hi
    printf::<i32>("%d\n", yn(string_is_empty(&greet))); // 0

    // equality compares bytes, not identity
    let a: String = string_from_str("abc");
    let b: String = string_from_str("abc");
    let c: String = string_from_str("abd");
    printf::<i32>("%d\n", yn(string_eq(&a, &b))); // 1
    printf::<i32>("%d\n", yn(string_eq(&a, &c))); // 0

    // clear empties the logical length without freeing the buffer
    string_clear(&a);
    printf::<i32>("%d\n", yn(string_is_empty(&a))); // 1
    printf::<u64>("%llu\n", string_len(&a));        // 0

    // the buffer doubles to absorb many pushes past its initial capacity
    let big: String = string_with_capacity(4u64);
    let i: i32 = 0;
    while (i < 100) {
        string_push_byte(&big, 120u8); // 'x'
        i = i + 1;
    }
    printf::<u64>("%llu\n", string_len(&big));             // 100
    printf::<i32>("%d\n", yn(string_cap(&big) >= 100u64)); // 1

    string_free(&s);
    string_free(&greet);
    string_free(&a);
    string_free(&b);
    string_free(&c);
    string_free(&big);
    return 0;
}
