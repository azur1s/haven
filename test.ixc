@inline(always) extern print_float(f: f32) void;

proc lowpass(state: *f32, x: f32, coeff: f32) f32 {
    *state = coeff * *state + (1.0 - coeff) * x;
    return *state;
}

@alloc(false)
@export
proc process(buffer: *[]f32, state: *f32) {
    let coeff: f32 = 0.8;
    let i: i32 = 0;
    while (i < len(*buffer)) {
        (*buffer)[i] = lowpass(state, (*buffer)[i], coeff);
        i = i + 1;
    }
}

proc main() {
    let dspbuf: []f32 = [1.0, 0.9, 0.5, 0.1, 0.0];
    let state: f32 = 0.0;
    process(&dspbuf, &state);

    let i: i32 = 0;
    while (i < len(dspbuf)) {
        print_float(dspbuf[i]);
        i = i + 1;
    }

    // 0.2000
    // 0.3400
    // 0.3720
    // 0.3176
    // 0.25408
}