{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Haven",
  "scopeName": "source.haven",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.haven",
          "match": "\\b(let|if|else|return|while|break|continue|proc|extern|const|struct|enum|import|pub|match)\\b"
        },
        {
          "name": "constant.language.haven",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.operator.haven",
          "match": "(=|<|>|\\+|\\-|\\*|/|::|->)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.haven",
          "match": "\\b(void|bool|str|i8|i32|i64|u8|u32|u64|f32|f64)\\b"
        },
        {
          "name": "entity.name.type.haven",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.haven",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.haven",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.haven",
          "match": "//.*$"
        }
      ]
    }
  }
}